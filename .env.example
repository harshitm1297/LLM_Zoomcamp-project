# Required only when generated answers are requested.
GROQ_API_KEY=your-groq-api-key

# Required only for a live TMDB refresh.
TMDB_API_KEY=your-tmdb-api-key
TMDB_LANGUAGE=en-US
TMDB_START_DATE=2025-01-01
TMDB_END_DATE=2026-12-31
TMDB_MOVIE_LIMIT=100
TMDB_TV_LIMIT=100

EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
# Use "hashing" only for a zero-download smoke test; BGE is the default.
EMBEDDING_BACKEND=sentence-transformers
GROQ_MODEL=llama-3.1-8b-instant
PROMPT_VARIANT=strict
RETRIEVAL_TOP_K=5
RETRIEVAL_STRATEGY=bm25
ENABLE_QUERY_REWRITING=true
CHUNK_WORDS=180
CHUNK_OVERLAP=30
MOODLENS_DB_PATH=runtime/moodlens.sqlite3
MOODLENS_ARTIFACTS_DIR=artifacts
